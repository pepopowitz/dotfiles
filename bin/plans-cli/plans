#!/usr/bin/env zsh
# plans: manage plan and brainstorm docs in external Claude Code project storage.
# Docs live in ~/.claude/projects/<slug>/{plans,brainstorms}/ — outside the repo
# so they never appear in git status.
#
# Requires: ripgrep (rg) for tag search (BSD grep lacks \b support).

set -u

usage() {
  cat <<EOF
Usage: plans [command] [args]

Commands:
  list [--plans|--brainstorms]  List active docs (default: both)
  tagged <tag>          List docs matching a tag
  tags                  List all tags (excluding ls-* tickets)
  in <tag|file>         Copy docs into the repo (by tag or filename)
  out <tag|file|--all>  Move docs from the repo back to external storage
  path <file>           Print the full external path to a doc
  edit <file>           Open a doc in VS Code
  archive <file|--older-than N>  Archive a doc or all active docs older than N days
  archived              List archived docs
  unarchive <file>      Restore an archived doc
  keep <file>           Mark a doc as keep (protected from --older-than)
  unkeep <file>         Remove keep mark from a doc
  delete <file|--older-than N>  Delete an archived doc or all archived docs older than N days
  dir                   Print the external storage root for this project
  help                  Show this message
EOF
}

_claude_project_dir() {
  if [[ -n "${PLANS_PROJECT_DIR:-}" ]]; then
    echo "$PLANS_PROJECT_DIR"
    return
  fi
  local slug
  slug=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
  slug="${slug//\//-}"
  slug="${slug//./-}"
  echo "$HOME/.claude/projects/$slug"
}

_plan_is_archived() {
  awk 'NR==1 && /^---$/{in_fm=1; next} in_fm && /^---$/{exit} in_fm && /^status:[[:space:]]*archived/{found=1} END{exit !found}' "$1"
}

_plan_has_keep_tag() {
  awk 'NR==1 && /^---$/{in_fm=1; next} in_fm && /^---$/{exit} in_fm && /^tags:/{sub(/^tags:[[:space:]]*/, ""); print}' "$1" \
    | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -qx 'keep'
}

_plan_filename_date() {
  basename "$1" | sed -E 's/^[a-z]-([0-9]{4}-[0-9]{2}-[0-9]{2}).*/\1/'
}

_plan_is_older_than() {
  local file="$1" days="$2"
  local file_date cutoff
  file_date=$(_plan_filename_date "$file")
  cutoff=$(date -v-${days}d +%Y-%m-%d)
  [[ "$file_date" < "$cutoff" ]]
}

_plan_find_file() {
  local base="$(_claude_project_dir)"
  local subdir file
  for subdir in plans brainstorms; do
    file="$base/$subdir/$1"
    [[ -f "$file" ]] && echo "$file" && return 0
  done
  echo "Not found: $1" >&2
  return 1
}

# Returns all copies of a file (external + repo), one per line.
# Used by commands that modify frontmatter so both copies stay in sync.
_plan_all_copies() {
  local base="$(_claude_project_dir)"
  local name="$1"
  local subdir
  for subdir in plans brainstorms; do
    [[ -f "$base/$subdir/$name" ]] && echo "$base/$subdir/$name"
    [[ -f "docs/$subdir/$name" ]] && echo "docs/$subdir/$name"
  done
}

_copy_to_repo() {
  local f="$1"
  local base="$(_claude_project_dir)"
  local dest
  if [[ "$f" == "$base/brainstorms/"* ]]; then
    dest=docs/brainstorms
  else
    dest=docs/plans
  fi
  mkdir -p "$dest"
  cp "$f" "$dest/$(basename "$f")"
  echo "  $(basename "$f") → $dest"
}

cmd_list() {
  local filter="${1:-}"
  local base="$(_claude_project_dir)"
  mkdir -p "$base/plans" "$base/brainstorms"

  local -a dirs
  case "$filter" in
    --plans)      dirs=("$base/plans") ;;
    --brainstorms) dirs=("$base/brainstorms") ;;
    *)            dirs=("$base/plans" "$base/brainstorms") ;;
  esac

  local section="" kind f
  for f in ${^dirs}/*(NOm); do
    [[ -f "$f" ]] || continue
    if ! _plan_is_archived "$f"; then
      if [[ "$f" == "$base/plans/"* ]]; then
        kind="plans"
      else
        kind="brainstorms"
      fi
      if [[ "$kind" != "$section" ]]; then
        [[ -n "$section" ]] && echo
        echo "$kind:"
        section="$kind"
      fi
      echo "  $(basename "$f")"
    fi
  done
}

cmd_tagged() {
  local base="$(_claude_project_dir)"
  mkdir -p "$base/plans" "$base/brainstorms"
  rg -l "tags:.*\b${1}\b" "$base/plans" "$base/brainstorms" | while read -r f; do
    basename "$f"
  done
}

_move_to_external() {
  local base="$(_claude_project_dir)"
  local file="$1"
  local src subdir
  if [[ -f "docs/brainstorms/$file" ]]; then
    src="docs/brainstorms/$file"
    subdir=brainstorms
  elif [[ -f "docs/plans/$file" ]]; then
    src="docs/plans/$file"
    subdir=plans
  else
    echo "Not found in docs/plans/ or docs/brainstorms/: $file" >&2
    return 1
  fi
  mkdir -p "$base/$subdir"
  mv "$src" "$base/$subdir/$file"
  git rm --cached "$src" 2>/dev/null || true
  echo "  $file → external ($subdir)"
}

cmd_in() {
  local arg="$1"
  local base="$(_claude_project_dir)"
  mkdir -p "$base/plans" "$base/brainstorms"

  # Try as filename first
  local file
  if file=$(_plan_find_file "$arg" 2>/dev/null); then
    _copy_to_repo "$file"
    return 0
  fi

  # Fall back to tag search
  local -a matches
  matches=("${(@f)$(rg -l "tags:.*\b${arg}\b" "$base/plans" "$base/brainstorms" 2>/dev/null)}")
  if [[ ${#matches[@]} -eq 0 || -z "${matches[1]}" ]]; then
    echo "No docs matching tag or filename '$arg'" >&2
    return 1
  fi
  local f
  for f in "${matches[@]}"; do
    _copy_to_repo "$f"
  done
}

cmd_out() {
  local arg="$1"
  local base="$(_claude_project_dir)"

  # Move all untracked plan/brainstorm docs out of the repo
  if [[ "$arg" == "--all" ]]; then
    local moved=0
    local f
    for f in $(git ls-files --others --exclude-standard -- docs/plans/ docs/brainstorms/ 2>/dev/null); do
      _move_to_external "$(basename "$f")"
      moved=1
    done
    [[ $moved -eq 1 ]] || { echo "No untracked docs to move out" >&2; return 1; }
    return 0
  fi

  # Try as filename first
  if [[ -f "docs/brainstorms/$arg" ]] || [[ -f "docs/plans/$arg" ]]; then
    _move_to_external "$arg"
    return 0
  fi

  # Fall back to tag search across repo docs
  local -a matches
  matches=()
  local dir
  for dir in docs/plans docs/brainstorms; do
    [[ -d "$dir" ]] || continue
    local -a found
    found=("${(@f)$(rg -l "tags:.*\b${arg}\b" "$dir" 2>/dev/null)}")
    [[ ${#found[@]} -gt 0 && -n "${found[1]}" ]] && matches+=("${found[@]}")
  done

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "No docs matching tag or filename '$arg'" >&2
    return 1
  fi
  local f
  for f in "${matches[@]}"; do
    _move_to_external "$(basename "$f")"
  done
}

cmd_tags() {
  local base="$(_claude_project_dir)"
  mkdir -p "$base/plans" "$base/brainstorms"
  local f
  for f in "$base"/{plans,brainstorms}/*(N); do
    [[ -f "$f" ]] || continue
    _plan_is_archived "$f" && continue
    awk 'NR==1 && /^---$/{in_fm=1; next} in_fm && /^---$/{exit} in_fm && /^tags:/{sub(/^tags:[[:space:]]*/, ""); print}' "$f"
  done | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^ls-' | grep -v '^$' | sort -u
}

cmd_path() {
  _plan_find_file "$1"
}

cmd_edit() {
  local path
  path=$(_plan_find_file "$1") || return 1
  /usr/bin/open -a "Visual Studio Code" "$path"
}

cmd_archive() {
  if [[ "$1" == "--older-than" ]]; then
    local days="${2:?Usage: plans archive --older-than <days>}"
    local base="$(_claude_project_dir)"
    mkdir -p "$base/plans" "$base/brainstorms"
    local count=0 f
    for f in "$base"/{plans,brainstorms}/*(NOm); do
      [[ -f "$f" ]] || continue
      _plan_is_archived "$f" && continue
      _plan_has_keep_tag "$f" && continue
      if _plan_is_older_than "$f" "$days"; then
        local copy
        for copy in $(_plan_all_copies "$(basename "$f")"); do
          sed -i '' 's/^status:.*$/status: archived/' "$copy"
        done
        echo "  $(basename "$f") → archived"
        count=$((count + 1))
      fi
    done
    [[ $count -gt 0 ]] || echo "No plans older than $days days to archive"
    return 0
  fi

  # Verify the file exists in external storage
  _plan_find_file "$1" >/dev/null || return 1
  local copy
  for copy in $(_plan_all_copies "$1"); do
    sed -i '' 's/^status:.*$/status: archived/' "$copy"
  done
  echo "  $1 → archived"
}

cmd_archived() {
  local base="$(_claude_project_dir)"
  mkdir -p "$base/plans" "$base/brainstorms"
  local f
  for f in "$base"/{plans,brainstorms}/*(NOm); do
    [[ -f "$f" ]] || continue
    if _plan_is_archived "$f"; then echo "$(basename "$f")"; fi
  done
}

cmd_unarchive() {
  _plan_find_file "$1" >/dev/null || return 1
  local copy
  for copy in $(_plan_all_copies "$1"); do
    sed -i '' 's/^status:[[:space:]]*archived$/status: draft/' "$copy"
  done
  echo "  $1 → restored"
}

cmd_keep() {
  local file
  file=$(_plan_find_file "$1") || return 1
  if _plan_has_keep_tag "$file"; then
    echo "  $1 already has keep tag"
    return 0
  fi
  local copy
  for copy in $(_plan_all_copies "$1"); do
    if grep -q '^tags:' "$copy"; then
      sed -i '' '/^tags:/ s/$/, keep/' "$copy"
    else
      sed -i '' '/^---$/,/^---$/ { /^status:/ a\
tags: keep
}' "$copy"
    fi
  done
  echo "  $1 → keep"
}

cmd_unkeep() {
  local file
  file=$(_plan_find_file "$1") || return 1
  if ! _plan_has_keep_tag "$file"; then
    echo "  $1 does not have keep tag"
    return 0
  fi
  local copy
  for copy in $(_plan_all_copies "$1"); do
    sed -i '' '/^tags:/ {
      s/, keep$//
      s/, keep,/,/
      s/^tags: keep, /tags: /
      s/^tags: keep$/tags:/
    }' "$copy"
  done
  echo "  $1 → unkeep"
}

cmd_delete() {
  if [[ "$1" == "--older-than" ]]; then
    local days="${2:?Usage: plans delete --older-than <days>}"
    local base="$(_claude_project_dir)"
    mkdir -p "$base/plans" "$base/brainstorms"
    local count=0 f
    for f in "$base"/{plans,brainstorms}/*(NOm); do
      [[ -f "$f" ]] || continue
      _plan_is_archived "$f" || continue
      _plan_has_keep_tag "$f" && continue
      if _plan_is_older_than "$f" "$days"; then
        rm "$f"
        echo "  $(basename "$f") → deleted"
        count=$((count + 1))
      fi
    done
    [[ $count -gt 0 ]] || echo "No archived plans older than $days days to delete"
    return 0
  fi

  local file
  file=$(_plan_find_file "$1") || return 1
  if ! _plan_is_archived "$file"; then
    echo "Refusing to delete: $1 is not archived. Archive it first." >&2
    return 1
  fi
  rm "$file"
  echo "  $1 → deleted"
}

case "${1:-list}" in
  list)      cmd_list "${2:-}" ;;
  tagged)    [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_tagged "$2" ;;
  tags)      cmd_tags ;;
  dir)       _claude_project_dir ;;
  in)        [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_in "$2" ;;
  out)       [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_out "$2" ;;
  path)      [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_path "$2" ;;
  edit)      [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_edit "$2" ;;
  archive)   [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_archive "$2" "${3:-}" ;;
  archived)  cmd_archived ;;
  unarchive) [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_unarchive "$2" ;;
  keep)      [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_keep "$2" ;;
  unkeep)    [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_unkeep "$2" ;;
  delete)    [[ $# -ge 2 ]] || { usage; exit 1; }; cmd_delete "$2" "${3:-}" ;;
  --plans|--brainstorms) cmd_list "$1" ;;
  help|--help|-h) usage ;;
  *) echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
