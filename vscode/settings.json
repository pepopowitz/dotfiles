{
  "workbench.colorCustomizations": {
    "selection.background": "#e4af8c" // so that I can read selected text in search input fields
    // "list.activeSelectionBackground": "#dddddd",
    // "list.activeSelectionForeground": "#395063",
    // "list.focusBackground": "#dddddd",
    // "list.highlightForeground": "#2f6f9f",
    // "list.hoverBackground": "#eeeeee",
    // "list.inactiveSelectionBackground": "#eeeeee",
    // "list.inactiveSelectionForeground": "#395063"
  },
  "editor.fontFamily": "'Source Code Pro', Menlo, Monaco, 'Courier New', monospace",
  "editor.tabSize": 2,
  "editor.minimap.enabled": false,
  "window.title": "${rootName}${separator}${activeEditorMedium}",
  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",
  "explorer.confirmDragAndDrop": false,
  "files.defaultLanguage": "markdown",
  "workbench.tree.renderIndentGuides": "none",
  "terminal.integrated.fontWeight": "500",
  "terminal.integrated.fontFamily": "SauceCodePro Nerd Font Mono",
  "breadcrumbs.enabled": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.accessibilitySupport": "off",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "never"
  },
  "editor.wrappingIndent": "indent",
  "diffEditor.ignoreTrimWhitespace": false,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "git.alwaysShowStagedChangesResourceGroup": true,
  "screencastMode.onlyKeyboardShortcuts": true,
  "githubPullRequests.queries": [
    {
      "label": "Local Pull Request Branches",
      "query": "default"
    },
    {
      "label": "Waiting For My Review",
      "query": "repo:${owner}/${repository} is:open review-requested:${user}"
    },
    {
      "label": "Assigned To Me",
      "query": "repo:${owner}/${repository} is:open assignee:${user}"
    },
    {
      "label": "Created By Me (open)",
      "query": "repo:${owner}/${repository} is:open author:${user}"
    },
    {
      "label": "Created By Me (all)",
      "query": "repo:${owner}/${repository} author:${user}"
    },
    {
      "label": "All Open",
      "query": "default"
    }
  ],
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "editor.renderLineHighlight": "all",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "git.confirmSync": false,
  "svg.preview.transparencyGrid": false,
  "svg.preview.boundingBox": true,
  "editor.inlineSuggest.enabled": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "githubPullRequests.pullBranch": "never",
  "editor.stickyScroll.enabled": true,
  "workbench.sideBar.location": "right",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "yaml": false
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "markdown.validate.enabled": true,
  "command-runner.commands": {
    "append markdown reference links": "md_links '${file}'"
  },
  "editor.autoClosingQuotes": "beforeWhitespace",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "workbench.colorTheme": "Feather",
  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "window.zoomLevel": 0,
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // npm install spawns a gajillion rg processes (https://github.com/microsoft/vscode/issues/98594):
  "search.followSymlinks": false,
  "dotnetAcquisitionExtension.existingDotnetPath": [
    {
      "extensionId": "ms-dotnettools.csharp",
      "path": "/usr/local/share/dotnet/dotnet"
    }
  ],
  "editor.wordWrap": "on",
  "workbench.editor.empty.hint": "hidden",
  "github.copilot.nextEditSuggestions.enabled": true,
  "markdown.marp.browser": "edge",
  "prettier.prettierPath": "./node_modules/prettier",
  "terminal.integrated.suggest.enabled": false,
  "claudeCode.preferredLocation": "panel",
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.HEIC": "default"
  }
}
