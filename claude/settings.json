{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh \"Excuse me?\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh \"Hey bruh...\" \"Pssst...\" \"Baby come back...\" \"Yoohoo...\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/notify.sh \"As you wish...\" \"All set chief...\" \"Baby come back...\" \"What's next???\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "compound-engineering@every-marketplace": true,
    "frontend-design@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "mcpServers": {
    "github-pr-review": {
      "command": "node",
      "args": [
        "/Users/stevenhicks/.claude/mcp-servers/github-pr-review/index.js"
      ]
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754333339275
  }
}
